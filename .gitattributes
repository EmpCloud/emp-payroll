# Force LF line endings everywhere — critical for Windows dev + Linux deploy
# This overrides git's core.autocrlf setting per-repo

* text=auto eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar.gz binary
