# Database — change DB_PROVIDER to "postgres" or "mongodb" as needed
DB_PROVIDER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=emp_payroll

# MongoDB (only when DB_PROVIDER=mongodb)
MONGO_URI=mongodb://localhost:27017/emp_payroll

# JWT
JWT_SECRET=change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Payroll
PAYROLL_COUNTRY=IN
PAY_FREQUENCY=monthly

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=payroll@empcloud.com
